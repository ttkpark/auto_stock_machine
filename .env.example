# =============================================
# [사용 방법]
# 이 파일을 복사하여 '.env' 로 이름을 바꾼 뒤,
# 아래 각 항목에 실제 발급받은 키를 채워 넣으세요.
# .env 파일은 절대 GitHub에 올리지 마세요!
# =============================================

# -----------------------------------------------
# 한국투자증권 KIS Developers API
# 발급처: https://apiportal.koreainvestment.com
# -----------------------------------------------

# 모의투자 (테스트용)
KIS_MOCK_APP_KEY=여기에_모의투자_앱키를_입력하세요
KIS_MOCK_APP_SECRET=여기에_모의투자_앱시크릿을_입력하세요
KIS_MOCK_ACCOUNT_NUMBER=여기에_모의투자_계좌번호를_입력하세요

# 실전투자 (실제 돈이 움직임 - 신중하게!)
KIS_REAL_APP_KEY=여기에_실전투자_앱키를_입력하세요
KIS_REAL_APP_SECRET=여기에_실전투자_앱시크릿을_입력하세요
KIS_REAL_ACCOUNT_NUMBER=여기에_실전투자_계좌번호를_입력하세요

# -----------------------------------------------
# Google Gemini API
# 발급처: https://aistudio.google.com/app/apikey
# -----------------------------------------------
GEMINI_API_KEY=여기에_Gemini_API_키를_입력하세요

# -----------------------------------------------
# Anthropic Claude API
# 발급처: https://console.anthropic.com
# -----------------------------------------------
CLAUDE_API_KEY=여기에_Claude_API_키를_입력하세요

# -----------------------------------------------
# OpenAI GPT API (선택사항)
# 발급처: https://platform.openai.com/api-keys
# -----------------------------------------------
OPENAI_API_KEY=여기에_OpenAI_API_키를_입력하세요

# -----------------------------------------------
# Telegram Bot
# 발급처: 텔레그램에서 @BotFather 에게 /newbot
# -----------------------------------------------
TELEGRAM_BOT_TOKEN=여기에_텔레그램_봇_토큰을_입력하세요
TELEGRAM_CHAT_ID=여기에_본인의_텔레그램_채팅ID를_입력하세요

# -----------------------------------------------
# 시스템 설정
# -----------------------------------------------
# True = 실전투자 (실제 계좌), False = 모의투자 (가상 계좌)
IS_REAL_TRADING=False
